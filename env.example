# --- Database ---
DATABASE_URL=postgresql+psycopg://asset_pipeline:asset_pipeline@localhost:5433/asset_pipeline

# --- Google ---
# Service account JSON key path (used for both Sheets and Drive)
GOOGLE_APPLICATION_CREDENTIALS=./.secrets/google-service-account.json
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_DRIVE_LIFESTYLE_FOLDER_ID=
GOOGLE_SHEETS_MASTER_ID=
GOOGLE_SHEETS_RANGE=Products!A1:Z10000

# --- AWS ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PREFIX=

# --- Pipeline ---
PIPELINE_CONFIG_PATH=./pipeline.config.toml
LOG_LEVEL=INFO
